name: neara-location-chat
region: nyc
services:
  - name: web
    environment_slug: node-js
    git:
      repo_clone_url: https://github.com/YOUR_USER/YOUR_REPO.git
      branch: main
    source_dir: /
    run_command: npm start
    http_port: 8080
    instance_count: 1
    instance_size_slug: apps-s-1vcpu-0.5gb
    envs:
      - key: HOST
        value: 0.0.0.0
        scope: RUN_TIME
        type: GENERAL
      - key: PORT
        value: "8080"
        scope: RUN_TIME
        type: GENERAL
      - key: NODE_ENV
        value: production
        scope: RUN_TIME
        type: GENERAL
      - key: OPENAI_MODEL
        value: gpt-5.2
        scope: RUN_TIME
        type: GENERAL
    health_check:
      http_path: /api/health
ingress:
  rules:
    - component:
        name: web
      match:
        path:
          prefix: /
alerts:
  - rule: DEPLOYMENT_FAILED
  - rule: DOMAIN_FAILED
